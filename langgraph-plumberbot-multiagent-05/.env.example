# ── Required (at least one) ───────────────────────────────────────────────────

# Anthropic API key — used for all LLM generation (required)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key — used ONLY for RAG embeddings (text-embedding-3-small)
# Optional: if omitted, the knowledge subagent falls back to BM25 keyword search
# OPENAI_API_KEY=sk-...

# ── Optional overrides ────────────────────────────────────────────────────────

# Anthropic model (default: claude-sonnet-4-6)
# ANTHROPIC_MODEL=claude-opus-4-8

# Business database path (default: db/plumberbot.db, relative to project root)
# BUSINESS_DB_PATH=/data/plumberbot.db

# Checkpoint database path (default: /tmp/plumberbot_checkpoints.db)
# CHECKPOINT_DB_PATH=/data/plumberbot_checkpoints.db
