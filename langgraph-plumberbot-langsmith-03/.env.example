# ── Server-side (used by the graph nodes running in LangGraph Server) ──────────
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the default model (default: claude-sonnet-4-6)
# ANTHROPIC_MODEL=claude-opus-4-8

# ── LangSmith (required for langgraph deploy; optional for langgraph dev) ──────
LANGSMITH_API_KEY=lsv2_pt_...

# ── Client-side (where the CLI / Next.js app connects) ────────────────────────
# Default: local dev server started with `langgraph dev`
LANGGRAPH_URL=http://127.0.0.1:2024
# After cloud deployment, replace with:
# LANGGRAPH_URL=https://<deployment-id>.us.langgraph.app
