# Required — get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optional model override (default: claude-sonnet-4-6)
# ANTHROPIC_MODEL=claude-opus-4-8

# SQLite database path (default: /tmp/plumberbot.db)
# Free HF Spaces: /tmp is ephemeral — state resets on cold start
# Pro HF Spaces: enable Persistent Storage, then use:
# DB_PATH=/data/plumberbot.db
